  "segments": [
    {
      "name": "Business Email Signups",
      "handle": "seg_email_business",
      "predicates": [
        {
          "field": "email_type",
          "operator": "eq",
          "value": "business"
        }
      ]
    },
    {
      "name": "Personal Email Signups",
      "handle": "seg_email_personal",
      "predicates": [
        {
          "field": "email_type",
          "operator": "eq",
          "value": "personal"
        }
      ]
    },
    {
      "name": "New Users (first 3 days)",
      "handle": "seg_eng_new",
      "predicates": [
        {
          "field": "days_since_signup",
          "operator": "lte",
          "value": "3"
        }
      ]
    },
    {
      "name": "Active Users",
      "handle": "seg_eng_active",
      "predicates": [
        {
          "field": "engagement_score",
          "operator": "gte",
          "value": "60"
        }
      ]
    },
    {
      "name": "Inactive Users",
      "handle": "seg_eng_inactive",
      "predicates": [
        {
          "field": "days_since_active",
          "operator": "gte",
          "value": "14"
        }
      ]
    },
    {
      "name": "Buyers",
      "handle": "seg_buyer",
      "predicates": [
        {
          "field": "has_purchased",
          "operator": "eq",
          "value": "true"
        }
      ]
    },
    {
      "name": "Non-Buyers",
      "handle": "seg_non_buyer",
      "predicates": [
        {
          "field": "has_purchased",
          "operator": "eq",
          "value": "false"
        }
      ]
    },
    {
      "name": "Failed Payment",
      "handle": "seg_billing_failed",
      "predicates": [
        {
          "field": "billing_status",
          "operator": "eq",
          "value": "failed"
        }
      ]
    },
    {
      "name": "Late Payment",
      "handle": "seg_billing_late",
      "predicates": [
        {
          "field": "billing_status",
          "operator": "eq",
          "value": "late"
        }
      ]
    },
    {
      "name": "Monthly Pro (annual upsell)",
      "handle": "seg_plan_nudge_annual",
      "predicates": [
        {
          "field": "plan",
          "operator": "eq",
          "value": "pro"
        },
        {
          "field": "billing_period",
          "operator": "eq",
          "value": "monthly"
        }
      ]
    }
  ],
