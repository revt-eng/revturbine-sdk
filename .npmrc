# @revt-eng/* are published to GitHub Packages. CI authenticates with the
# repo's GITHUB_TOKEN (same-org package read). The token is an env placeholder,
# not a secret. Hoisted layout so web-sdk's source resolves @revt-eng/* from the
# repo-root node_modules during the TypeDoc docs build.
@revt-eng:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
node-linker=hoisted
