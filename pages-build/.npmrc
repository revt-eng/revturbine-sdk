@revt-eng:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
# pnpm parity with the npm install this package used to run under:
# - hoisted layout so Astro/Vite/starlight tooling sees a flat node_modules
# - run pre/post scripts (prebuild -> bundle:sdk-local must fire before astro build)
node-linker=hoisted
enable-pre-post-scripts=true
